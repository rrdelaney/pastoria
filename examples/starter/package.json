    "@pastoria/server": "workspace:*",
    "@stylexjs/stylex": "catalog:",
    "dotenv": "catalog:",
    "express": "catalog:",
    "graphql": "catalog:",
    "grats": "catalog:",
    "radix3": "^1.1.2",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-relay": "catalog:",
    "relay-runtime": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@pastoria/vite": "workspace:*",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-relay": "catalog:",
    "@types/relay-runtime": "catalog:",
    "babel-plugin-react-compiler": "^1.0.0",
    "babel-plugin-relay": "catalog:",
    "relay-compiler": "catalog:",
