{
  "name": "@pastoria/example-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=production pastoria-server",
    "generate": "grats && relay-compiler && pastoria generate",
    "format": "vp fmt .",
    "build": "vp build",
    "dev": "vp dev",
    "check": "vp check"
